# Copy this file to ".env.local" and fill in what you need.
# Leave EVERYTHING blank to run the zero-setup DEMO (localStorage auth/state).
# See SETUP.md for the full walkthrough.

# ── Real backend toggle ───────────────────────────────────────────────
# Set to "true" to enable Auth.js + Neon + Stripe. Requires DATABASE_URL
# and AUTH_SECRET below (plus Google / Stripe keys for those features).
NEXT_PUBLIC_USE_DB=

# ── AI plan generation (optional; works in demo AND real mode) ─────────
# https://console.anthropic.com → API Keys. Read only server-side.
ANTHROPIC_API_KEY=
# Model is chosen by tier (Sonnet for free, Opus for smart/guru).
# Force a single model everywhere (optional):
# SKILLSPRINTER_MODEL=claude-sonnet-4-6

# ── Database — Neon Postgres (https://neon.tech) ───────────────────────
# Pooled connection string used by the app at runtime:
DATABASE_URL=
# Direct (non-pooled) connection used for migrations:
DIRECT_URL=

# ── Auth.js / NextAuth v5 ──────────────────────────────────────────────
# Generate one: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=
# Google OAuth — https://console.cloud.google.com → APIs & Services → Credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# In production set your canonical URL (local dev auto-detects):
# AUTH_URL=https://your-domain.com

# ── Stripe (https://dashboard.stripe.com) ──────────────────────────────
STRIPE_SECRET_KEY=
# From `stripe listen` (local) or the Dashboard webhook endpoint (prod):
STRIPE_WEBHOOK_SECRET=
# Price IDs — Dashboard → Products → (each price) → "API ID" (price_…):
STRIPE_PRICE_SMART_MONTH=
STRIPE_PRICE_SMART_YEAR=
STRIPE_PRICE_GURU_MONTH=
STRIPE_PRICE_GURU_YEAR=

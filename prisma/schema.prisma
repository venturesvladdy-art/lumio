// SkillSprinter data model.
// Auth.js (NextAuth) tables + audit-first domain tables: every generated
// curriculum and its Q&A are stored immutably per (user, skill), and every
// answer is appended to the Attempt log — a full audit trail to build on.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon: pooled connection for the app, direct connection for migrations.
  directUrl = env("DIRECT_URL")
}

/* ───────────────── Auth.js models ───────────────── */

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  // Email + password sign-in (hashed with bcrypt; null for OAuth-only users).
  passwordHash String?

  // Plan & billing.
  tier                 String    @default("basic") // basic | smart | guru
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?
  stripePriceId        String?
  currentPeriodEnd     DateTime?
  /// A scheduled plan change that applies at currentPeriodEnd (downgrade/cancel).
  /// null = no pending change; "basic" = cancel at period end; else the lower tier.
  pendingTier          String?

  createdAt DateTime @default(now())

  /// v2: manual per-subarea starting-level overrides { subareaKey: level }
  subareaLevels Json?

  /// Phase 3: anonymous progress snapshots already claimed (idempotent claim).
  claimedAnonIds String[] @default([])
  /// Phase 6: bumped on password change to invalidate older JWTs.
  pwTokenVersion Int      @default(0)

  accounts   Account[]
  sessions   Session[]
  curricula  Curriculum[]
  attempts   Attempt[]
  auditEvents AuditEvent[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/* ───────────────── Domain: curricula, Q&A, audit ───────────────── */

/// One immutable record per generated learning plan (audit + the data to build on).
model Curriculum {
  id           String   @id @default(cuid())
  userId       String
  skillId      String
  skillName    String
  level        String // beginner | intermediate | advanced
  focus        String[] // selected focus values
  summaryEn    String   @db.Text
  summaryPl    String   @db.Text
  totalPlanned Int
  source       String // claude | bank | bank-fallback
  model        String? // model id when generated by Claude
  /// raw onboarding answers, kept so we can faithfully regenerate on upgrade
  answers      Json?
  /// Stage B: the skill area this drill targets (null for legacy full plans).
  areaId       String?
  areaName     String?
  /// v2: the catalogued subarea this drill targets.
  subareaKey   String?
  createdAt    DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions Question[]
  briefs    Brief[]
  attempts  Attempt[]

  @@index([userId, skillId])
  @@index([userId, skillId, areaId])
  @@index([createdAt])
}

/// Stage B: a short learning brief that primes 2–3 questions before a drill.
model Brief {
  id           String   @id @default(cuid())
  curriculumId String
  clientId     String // stable id referenced by its questions (e.g. "brief-0")
  title        String
  body         String   @db.Text
  orderIndex   Int
  createdAt    DateTime @default(now())

  curriculum Curriculum @relation(fields: [curriculumId], references: [id], onDelete: Cascade)

  @@index([curriculumId])
}

/// The generated Q&A items belonging to a curriculum (immutable).
model Question {
  id            String   @id @default(cuid())
  curriculumId  String
  /// stable id used by the client (e.g. "gen-ai-0" / "ai-1")
  clientId      String
  skillId       String
  difficulty    String
  /// mcq | truefalse | numeric | input | order | free  (defaults to mcq)
  type          String   @default("mcq")
  /// Stage B: the brief (clientId) this question belongs to, if any (legacy)
  briefClientId String?
  /// v2: catalogued subarea + canonical concept (kebab-case) for mastery dedup
  subareaKey    String?
  concept       String?
  questionEn    String   @db.Text
  questionPl    String   @db.Text
  optionsEn     String[]
  optionsPl     String[]
  correctIndex  Int
  /// Stage B: canonical answer (numeric) / model answer (free)
  answerText    String?  @db.Text
  /// v2: input-type accepted answers; order-type items + correct permutation
  acceptedAnswers String[] @default([])
  orderItems      String[] @default([])
  correctOrder    Int[]    @default([])
  /// Stage B: grading rubric for free-text questions
  rubric        String?  @db.Text
  /// v2: cached on-demand theory (generated once per question, re-read on re-tap)
  theory               String?  @db.Text
  theoryIncludesAnswer Boolean?
  explanationEn String   @db.Text
  explanationPl String   @db.Text
  xp            Int
  orderIndex    Int
  createdAt     DateTime @default(now())

  curriculum Curriculum @relation(fields: [curriculumId], references: [id], onDelete: Cascade)

  @@index([curriculumId])
  @@index([skillId])
  @@index([subareaKey])
  @@index([skillId, concept])
}

/// Append-only log of every answer a user submits.
model Attempt {
  id               String   @id @default(cuid())
  userId           String
  curriculumId     String?
  skillId          String
  areaId           String?
  /// v2: catalogued subarea + concept (copied from the answered question)
  subareaKey       String?
  concept          String?
  questionClientId String
  /// Stage B: question type answered (defaults to mcq)
  type             String   @default("mcq")
  /// nullable: free/numeric answers use responseText instead of an index
  selectedIndex    Int?
  /// Stage B: free-text / numeric response
  responseText     String?  @db.Text
  /// Stage B: AI score for free-text answers (0–5)
  score            Int?
  correct          Boolean
  xpGained         Int
  answeredAt       DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  curriculum Curriculum? @relation(fields: [curriculumId], references: [id], onDelete: SetNull)

  @@index([userId, skillId])
  @@index([userId, skillId, subareaKey])
  @@index([curriculumId])
  @@index([answeredAt])
}

/// Generic append-only audit events (signups, plan generation, billing changes).
model AuditEvent {
  id        String   @id @default(cuid())
  userId    String?
  type      String
  data      Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

/* ───────────────── v2: reusable Skill Taxonomy catalogue ───────────────── */

/// Phase 2: reusable, curated/generated Q&A shared across ALL users. Built
/// offline (batch API) and served forever at ~$0 — backs anonymous, unverified,
/// Basic, and the budget-exhausted state of paid tiers.
model BankQuestion {
  id              String   @id @default(cuid())
  skillId         String
  subareaKey      String
  concept         String
  difficulty      String // beginner | intermediate | advanced
  type            String   @default("mcq")
  questionEn      String   @db.Text
  questionPl      String   @db.Text
  optionsEn       String[]
  optionsPl       String[]
  correctIndex    Int
  answerText      String?  @db.Text
  acceptedAnswers String[] @default([])
  orderItems      String[] @default([])
  correctOrder    Int[]    @default([])
  explanationEn   String   @db.Text
  explanationPl   String   @db.Text
  theoryEn        String?  @db.Text
  theoryPl        String?  @db.Text
  xp              Int      @default(10)
  qualityState    String   @default("approved") // draft | approved | retired
  model           String?
  buildBatchId    String?
  createdAt       DateTime @default(now())

  @@index([skillId, subareaKey, difficulty])
  @@index([skillId, concept])
  @@index([qualityState])
}

/// Phase 4: append-only AI spend ledger — one row per live model call. Enforces
/// the "AI cost ≤ 20% of revenue" invariant and drives live-vs-bank routing.
model AiUsage {
  id                String   @id @default(cuid())
  userId            String? // null = anonymous (should be ~empty; anon is bank-only)
  kind              String // plan | theory | grade | taxonomy | areas | bank-build
  model             String
  inputTokens       Int
  outputTokens      Int
  cachedInputTokens Int      @default(0)
  costUsd           Float
  period            String // "YYYY-MM" for fast monthly rollup
  createdAt         DateTime @default(now())

  @@index([userId, period])
  @@index([period, kind])
}

/// One catalogued area→subarea breakdown per skill, shared across ALL users and
/// reused (generated once with a strong model, then cached). `areas` holds the
/// hierarchy as JSON: [{ areaKey, name, blurb, subareas: [{ subareaKey, name,
/// blurb, conceptTarget }] }].
model SkillTaxonomy {
  id            String   @id @default(cuid())
  skillSlug     String   @unique
  canonicalName String
  matchKey      String // normalized dedupe key
  kind          String   @default("standardized") // standardized | subjective
  origin        String   @default("ai-generated") // curated | ai-generated
  model         String?
  version       Int      @default(1)
  areas         Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([matchKey])
}
